{
  "expo": {
    "name": "Smart Notes App",
    "slug": "smart-notes-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shreyaupretyy.smartnotesapp"
    },
    "android": {
      "package": "com.shreyaupretyy.smartnotesapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "sdkVersion": "53.0.0",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to add images to your notes.",
          "cameraPermission": "The app needs access to your camera to take photos for your notes."
        }
      ]
    ],
    "owner": "shreyaupretyy"
  }
}